# Copy this file to .env and fill your credentials

# OpenAI API Configuration
# Required: Your OpenAI API key for LLM model access
OPENAI_API_KEY=sk-your-api-key-here

# Alternative: CHATGPT_API_KEY (will be mapped to OPENAI_API_KEY if not set)
# Kept for backward compatibility
# CHATGPT_API_KEY=sk-your-api-key-here

# Optional: Gateway/proxy base URL (Portkey or similar)
# OPENAI_BASE_URL=https://portkey.bain.dev/v1
# CHATGPT_API_BASE_URL=https://portkey.bain.dev/v1

# LLM_MODEL=gpt-4o